# Place all your secrets here. DO NOT commit the actual .env file.

# Global Settings
TZ="Europe/Amsterdam"
DOMAIN="example.com"
SECOND_DOMAIN="example.net"
DOCKER_ROOT="/home/<YOUR_LINUX_USER>/docker"
SYSTEM_USER="<YOUR_LINUX_USER>"
INTERNAL_HOST_IP="192.168.xxx.xxx"

# Frigate Settings
FRIGATE_RTSP_PASSWORD="<REPLACE_WITH_SECURE_PASSWORD>"
FRIGATE_MQTT_USER="frigate_user"
FRIGATE_MQTT_PASSWORD="<REPLACE_WITH_PASSWORD>"
# Setting to store snapshots in
GARAGE_FRIGATE_SNAPSHOTS="storage/<your defined location>"

# Home Assistant Settings
HA_USER="admin"
HA_PASSWORD="<REPLACE_WITH_PASSWORD>"
HA_MQTT_USER="homeassistant"
HA_MQTT_PASSWORD="<REPLACE_WITH_PASSWORD>"

# SMTP Relay Settings
SMTP_HOST="smtp.freedom.nl"
SMTP_PORT="587"
SMTP_TLS="yes"

# Nextcloud Database
NEXTCLOUD_DB_ROOT_PASSWORD="<REPLACE_WITH_DB_ROOT_PASSWORD>"
NEXTCLOUD_DB_PASSWORD="<REPLACE_WITH_DB_USER_PASSWORD>"
NEXTCLOUD_DB_USER="nextcloud"
NEXTCLOUD_DB_NAME="nextcloud"
NEXTCLOUD_TRUSTED_DOMAINS="nextcloud.example.com"

# Nextcloud Mail Settings
NEXTCLOUD_MAIL_FROM_ADDRESS="nextcloud"
NEXTCLOUD_MAIL_DOMAIN="example.com"
NEXTCLOUD_MAIL_SMTPHOST="smtp.freedom.nl"
NEXTCLOUD_MAIL_SMTPPORT="465"
NEXTCLOUD_MAIL_SMTPSECURE="ssl"
NEXTCLOUD_MAIL_SMTPAUTH="true"
NEXTCLOUD_MAIL_SMTPNAME="your_email@freedom.nl"
NEXTCLOUD_MAIL_SMTPPASSWORD="your_app_password"

# Forgejo
FORGEJO_USER="git"
FORGEJO_DB_USER="forgejo"
FORGEJO_DB_NAME="forgejo"
FORGEJO_DB_PASSWORD="<REPLACE_WITH_FORGEJO_DB_PASSWORD>"

# Step-CA & Security
STEP_CA_EMAIL="admin@example.com"
STEPCA_PASSWORD="<REPLACE_WITH_PASSWORD>"
STEPCA_PROVISIONER_NAME="admin@example.com"
STEPCA_PROVISIONER_PASSWORD="<REPLACE_WITH_STRONG_PASSWORD>"
STEP_CA_DNS_IP="<YOUR_SERVER_LOCAL_IP>"
STEPCAT_FINGERPRINT="<FINGERPRINT_FROM_STEP_CA>"
NPM_CERT_ID="npm-x"
CHAT_NPM_CERT_ID="npm-y"
SIGNUPS_ALLOWED="false"

# Signal API
SIGNAL_CLI_API_PASSWORD="<REPLACE_WITH_PASSWORD>"
SIGNAL_API_PORT="8090"

# Homarr / Dashboard
ICON_BLACKLIST_LOCAL="false"
ICON_DOWNLOAD_TIMEOUT=5000

# =============================================================================
# BACKUP CONFIGURATION (3-2-1 Strategy)
# =============================================================================

# --- Email & Monitoring ---
BACKUP_EMAIL="your_email@provider.com"

# --- Encryption ---
BACKUP_ENCRYPTION_KEY="<REPLACE_WITH_SECURE_PASSWORD>"

# --- Local Backup (USB 8TB) ---
BACKUP_LOCAL_TARGET="/mnt/usb-8tb/backups"
BACKUP_LOCAL_RETENTION_DAYS=7

# --- Off-site Backup (NAS/Windows PC) ---
BACKUP_OFFSITE_IP="192.168.178.15"
BACKUP_OFFSITE_USER="<YOUR_USER>"
BACKUP_OFFSITE_PASSWORD="<REPLACE_WITH_PASSWORD>"
BACKUP_OFFSITE_PATH="/volume1/backup_pi"
# Options: windows, linux, mac
BACKUP_OFFSITE_OS="linux"
BACKUP_OFFSITE_RETENTION_VERSIONS=7

# --- Wake-on-LAN (for Off-site Target) ---
BACKUP_OFFSITE_WOL="YES"
BACKUP_OFFSITE_MAC="<REPLACE_WITH_MAC_ADDRESS>"
BACKUP_OFFSITE_WOL_WAITPERIOD_SEC=30
BACKUP_OFFSITE_MAX_RETRIES=15
BACKUP_OFFSITE_RETRY_WAIT=6

# --- Backup Exclusions ---
INCLUDE_FRIGATE_DATA=false
INCLUDE_NEXTCLOUD_DATA=true

# External DNS server
EXTERNAL_DNS_IP=x.x.x.x
EXTERNAL_DNS_NAME="<full dns name of external dns server>"

# Netbox Infrastructure
NETBOX_API_TOKEN_PEPPERS="<REPLACE_WITH_AT_LEAST_50_RANDOM_CHARACTERS>"
NETBOX_SECRET_KEY="<REPLACE_WITH_AT_LEAST_50_RANDOM_CHARACTERS>"
NETBOX_DB_NAME="netbox"
NETBOX_DB_USER="netbox"
NETBOX_DB_PASSWORD="<REPLACE_WITH_SECURE_POSTGRES_PASSWORD>"
NETBOX_ALLOWED_HOSTS="localhost,127.0.0.1,netbox.${DOMAIN}"
NETBOX_CLUSTER_MAPPING="aaa.bbb.ccc.ddd:Cluster-1,aaa.bbb.ccc.ddd:Cluster-2,aaa.bbb.ccc.ddd:Cluster-3"

COTUR_SECRET="<REPLACE_WITH_A_SECURE_PASSWORD>"

# Garage is API compatible interface with Amazon's S3.
# The next DIRs are appended to the docker root.
GARAGE_ROOT="garage"
GARAGE_METADATA_DIR="garage/meta"
GARAGE_DATA_DIR="garage/data"

# --- Garage S3 Storage Secrets ---
# Generate a 32-byte hex secret using: openssl rand -hex 32
# NOTE: Do NOT use quotes around the hex string here.
GARAGE_RPC_SECRET=<REPLACE_WITH_HEX_SECRET_WITHOUT_QUOTES>

# -------------------------------------------------------------------
# SYNAPSE MATRIX CONFIGURATION (Optional)
# -------------------------------------------------------------------
# Uncomment and generate strong random values:
# SYNAPSE_SECRET_KEY="<generate with: openssl rand -base64 32>"
# SYNAPSE_DB_PASSWORD="<generate with: openssl rand -base64 24>"

# Element Web Config: Create ${DOCKER_ROOT}/element/config.json with:
# {
#   "default_server_url": "https://matrix.DOMAIN",
#   "brand": "Element"
# }

# Pushmatrix (Matrix notification API)
PUSHMATRIX_PASSWORD="<REPLACE_WITH_PASSWORD>"

# =============================================================================
# PORT MAPPING CONFIGURATION
# =============================================================================
# External port assignments

# --- Infrastructure ---
PORT_PORTAINER=9443

# --- Security & VPN ---
PORT_STEP_CA=9000

# --- DNS & Network ---
PORT_ADGUARD_DNS_TCP=53
PORT_ADGUARD_DNS_UDP=53
PORT_ADGUARD_WEB=3000
PORT_ADGUARD_DNS_HTTP=8080
PORT_MQTT=1883
PORT_MQTT_WS=9001

# --- Proxy (Nginx Proxy Manager) ---
PORT_NPM_HTTP=80
PORT_NPM_HTTPS=443
PORT_NPM_ADMIN=8181

# --- Storage & Cloud ---
PORT_NEXTCLOUD=8088

# --- Communication ---
PORT_COTURN=3478
PORT_SIGNAL_API=8090
PORT_HOMARR=7575

# --- Development ---
PORT_FORGEJO_SSH=2222

# --- Infrastructure Management ---
PORT_NETBOX=8085

# --- UniFi Controller ---
PORT_UNIFI_HTTPS=8444
PORT_UNIFI_STUN=3479
PORT_UNIFI_API=10080
PORT_UNIFI_SSDP=1900
PORT_UNIFI_GUEST_HTTPS=8843
PORT_UNIFI_GUEST_HTTP=8880
PORT_UNIFI_ADOPTION=6789
PORT_UNIFI_SYSLOG=5514

# --- Frigate ---
PORT_FRIGATE_WEB=5000
PORT_FRIGATE_WS=8971
PORT_FRIGATE_RTSP_RESTREAM=8554
PORT_FRIGATE_RTSP=8555

# =============================================================================
# SERVICE-SPECIFIC PORT CONFIGURATION
# =============================================================================
# Environment variables that reference ports

# --- Frigate ---
FRIGATE_MQTT_PORT=${PORT_MQTT}

# --- Coturn ---
COTURN_MIN_PORT=60000
COTURN_MAX_PORT=65535

# --- Forgejo ---
FORGEJO__SERVER__HTTP_PORT=3000

# --- UniFi Controller ---
MONGO_PORT=27017

# --- Optional (commented out) ---
# PORT_MATRIX_CONDUIT=6167
# SYNAPSE_PORT=8008

# =============================================================================
# GRAFANA + LOKI CONFIGURATION
# =============================================================================

# --- Ports ---
PORT_GRAFANA=3200
PORT_LOKI=3100

# --- Grafana ---
# Generate with: openssl rand -base64 16
GRAFANA_PASSWORD="<REPLACE_WITH_PASSWORD>"

# --- Loki ---
LOKI_RETENTION_DAYS=7
